                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "AVERAGE(analytical_training_summary[ObservationCount])",
            "lineageTag": "afe0b124-8543-4dbc-9e80-0431899fd0cc"
          },
          {
            "name": "Segs With Drops",
            "expression": "CALCULATE(DISTINCTCOUNT(analytical_training_summary[SegmentLabel]), analytical_training_summary[CategoriesDropped] > 0)",
            "formatString": "0",
            "lineageTag": "6140fbb9-656b-445f-ab96-f781496fbb89"
          }
        ],
