      {
        "name": "_Measures",
        "columns": [
          {
            "name": "Placeholder",
            "dataType": "string",
            "isHidden": true,
            "lineageTag": "9c6af9d8-246e-4606-b187-2a586e1a38fb",
            "sourceColumn": "Placeholder"
          }
        ],
        "isHidden": true,
        "lineageTag": "8e739718-f19b-4d2d-b8a7-2d60662638e8",
        "measures": [
          {
            "name": "SSE",
            "description": "Sum of Squared Errors. Weights large misses more heavily than MAE.",
            "displayFolder": "Error Metrics",
            "expression": "SUMX(analytical_test_results, analytical_test_results[SquaredError])",
            "formatString": "#,##0.00",
            "lineageTag": "c8814546-6a53-43ee-abfb-51652f818dfa"
          },
          {
            "name": "MSE",
            "description": "Mean Squared Error — average squared prediction error per record.",
            "displayFolder": "Error Metrics",
            "expression": "AVERAGEX(analytical_test_results, analytical_test_results[SquaredError])",
            "formatString": "#,##0.00",
            "lineageTag": "c56fa198-c298-4d38-b13c-97c5460ade55"
          },
          {
            "name": "RMSE",
            "description": "Root Mean Squared Error — in the same units as the outcome. Lower is better.",
            "displayFolder": "Error Metrics",
            "expression": "SQRT(AVERAGEX(analytical_test_results, analytical_test_results[SquaredError]))",
            "formatString": "#,##0.00",
            "lineageTag": "8098ff15-68c7-4480-81fc-dda83eabefac"
          },
          {
            "name": "MAE",
            "description": "Mean Absolute Error — average size of prediction error regardless of direction.",
            "displayFolder": "Error Metrics",
            "expression": "AVERAGEX(analytical_test_results, analytical_test_results[AbsoluteError])",
            "formatString": "#,##0.00",
            "lineageTag": "8f068187-7893-4976-a256-21d237f9628e"
          },
          {
            "name": "MAPE",
            "description": "Mean Absolute Percentage Error. Normalises error by outcome scale for cross-outcome comparison.",
            "displayFolder": "Error Metrics",
            "expression": "AVERAGEX(FILTER(analytical_test_results, NOT ISBLANK(analytical_test_results[PercentageError])), ABS(analytical_test_results[PercentageError]))",
            "formatString": "0.0%",
            "lineageTag": "3886a831-9046-4bac-ab77-2626f5c53b9b"
          },
          {
            "name": "Mean Error (Bias)",
            "description": "Mean Error — directional bias. Positive = overestimate, negative = underestimate.",
            "displayFolder": "Error Metrics",
            "expression": "AVERAGEX(analytical_test_results, analytical_test_results[Error])",
            "formatString": "+#,##0.00;-#,##0.00;0.00",
            "lineageTag": "1749d879-488a-4073-8874-d3b6126c9d6e"
          },
          {
            "name": "Expected Wins",
            "description": "Sum of predicted win probabilities — the number of wins the model expected.",
            "displayFolder": "Win % Calibration",
            "expression": "CALCULATE(SUM(analytical_test_results[PredictedValue]), analytical_test_results[OutcomeName] = \"WinPct\")",
            "formatString": "#,##0.0",
            "lineageTag": "ecc4310c-35bf-4689-a02e-80f1194e5401"
          },
          {
            "name": "Actual Wins",
            "description": "Actual number of won opportunities in the test dataset.",
            "displayFolder": "Win % Calibration",
            "expression": "CALCULATE(SUM(analytical_test_results[ActualValue]), analytical_test_results[OutcomeName] = \"WinPct\")",
            "formatString": "#,##0",
            "lineageTag": "bedc152d-25f0-45f3-92ef-9505b71aa60d"
          },
          {
            "name": "Win Rate Predicted",
            "description": "Average predicted win probability across test records.",
            "displayFolder": "Win % Calibration",
            "expression": "DIVIDE([Expected Wins], CALCULATE(COUNTROWS(analytical_test_results), analytical_test_results[OutcomeName] = \"WinPct\"))",
            "formatString": "0.0%",
            "lineageTag": "54bc3b2e-8d31-4c53-a038-7a4f7dc7c399"
          },
          {
            "name": "Win Rate Actual",
            "description": "Actual win rate observed in the test dataset.",
            "displayFolder": "Win % Calibration",
            "expression": "DIVIDE([Actual Wins], CALCULATE(COUNTROWS(analytical_test_results), analytical_test_results[OutcomeName] = \"WinPct\"))",
            "formatString": "0.0%",
            "lineageTag": "bb5b8898-6421-49e2-ab42-857e30c7aa5a"
          },
          {
            "name": "Win Rate Calibration Gap",
            "description": "Predicted minus actual win rate. Near zero = well calibrated model.",
            "displayFolder": "Win % Calibration",
            "expression": "[Win Rate Predicted] - [Win Rate Actual]",
            "formatString": "+0.0%;-0.0%;0.0%",
            "lineageTag": "2984b2dc-b4d9-4ddb-8289-17985209babc"
          },
          {
            "name": "Total Estimated Fees",
            "description": "Total estimated net fees across all months in scope.",
            "displayFolder": "Pipeline",
            "expression": "SUM(analytical_pipeline_results[EstimatedNetFees])",
            "formatString": "$#,##0",
            "lineageTag": "cffe9a28-a993-4367-8a3f-246ac590e73c"
          },
          {
            "name": "Total Estimated Margin",
            "description": "Total estimated margin dollars across all months in scope.",
            "displayFolder": "Pipeline",
            "expression": "SUM(analytical_pipeline_results[EstimatedMarginDollars])",
            "formatString": "$#,##0",
            "lineageTag": "383117bc-b507-454d-a801-fcd5069344d8"
          },
          {
            "name": "Total Estimated Jobs",
            "description": "Total estimated number of jobs starting across all months in scope.",
            "displayFolder": "Pipeline",
            "expression": "SUM(analytical_pipeline_results[EstimatedJobCount])",
            "formatString": "#,##0",
            "lineageTag": "c989d368-b6fd-490c-a848-3b8ad2418621"
          },
          {
            "name": "Avg Estimated Margin %",
            "description": "Blended estimated margin percentage across all jobs in scope.",
            "displayFolder": "Pipeline",
            "expression": "DIVIDE([Total Estimated Margin], [Total Estimated Fees])",
            "formatString": "0.0%",
            "lineageTag": "b5c72659-5a56-4111-85ac-183d63377694"
          },
          {
            "name": "Current Pipeline Jobs",
            "description": "Number of opportunities and jobs in the current pipeline.",
            "displayFolder": "Job Predictions",
            "expression": "CALCULATE(COUNTROWS(analytical_job_results), analytical_job_results[DatasetType] = \"Current\")",
            "formatString": "#,##0",
            "lineageTag": "a14a5515-281f-4e1c-9c1f-8b479891b975"
          },
          {
            "name": "Current Pipeline Estimated Fees",
            "description": "Total estimated net fees across current pipeline records.",
            "displayFolder": "Job Predictions",
            "expression": "CALCULATE(SUM(analytical_job_results[EstimatedNetFees]), analytical_job_results[DatasetType] = \"Current\")",
            "formatString": "$#,##0",
            "lineageTag": "fa73c3f8-6111-4e5b-b145-4d8fc3ddfe34"
          },
          {
            "name": "Current Pipeline Estimated Margin",
            "description": "Total estimated margin dollars across current pipeline records.",
            "displayFolder": "Job Predictions",
            "expression": "CALCULATE(SUM(analytical_job_results[EstimatedMarginDollars]), analytical_job_results[DatasetType] = \"Current\")",
            "formatString": "$#,##0",
            "lineageTag": "e20d65ba-17d2-4088-8c7c-cc33ca48003a"
          },
          {
            "name": "Probability-Weighted Fees",
            "description": "Estimated fees weighted by win probability — expected value of the open opportunity pipeline.",
            "displayFolder": "Job Predictions",
            "expression": "SUMX(FILTER(analytical_job_results, analytical_job_results[DatasetType] = \"Current\" && NOT ISBLANK(analytical_job_results[EstimatedWinPct])), analytical_job_results[EstimatedNetFees] * analytical_job_results[EstimatedWinPct])",
            "formatString": "$#,##0",
            "lineageTag": "29f919d8-145d-48c9-bf46-e2c7e684c58d"
          },
          {
            "name": "Total Segments",
            "description": "Total distinct segment-outcome combinations built from training data.",
            "displayFolder": "Training",
            "expression": "DISTINCTCOUNT(analytical_training_summary[SegmentKey])",
            "formatString": "#,##0",
            "lineageTag": "909b8dc9-21fb-42f8-a81e-75c75df8024a"
          },
          {
            "name": "Segments With Dropped Categories",
            "description": "Segments where at least one category was dropped to meet the minimum observation threshold.",
            "displayFolder": "Training",
            "expression": "CALCULATE(DISTINCTCOUNT(analytical_training_summary[SegmentKey]), analytical_training_summary[CategoriesDropped] > 0)",
            "formatString": "#,##0",
            "lineageTag": "99cb32c2-c45f-4c68-b30b-aff17d4ca89d"
          },
          {
            "name": "Avg Observations Per Segment",
            "description": "Average number of historical observations backing each segment estimate.",
            "displayFolder": "Training",
            "expression": "AVERAGE(analytical_training_summary[ObservationCount])",
            "formatString": "#,##0",
            "lineageTag": "40dd36ec-cc51-4305-9acd-fec805a99b64"
          }
        ],
